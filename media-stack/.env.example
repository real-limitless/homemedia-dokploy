# ─────────────────────────────────────────────────────────────
# General Settings
# ─────────────────────────────────────────────────────────────
TZ=America/New_York
PUID=1000
PGID=1000

# ─────────────────────────────────────────────────────────────
# Rclone S3 Mount Settings (you can tweak these)
# ─────────────────────────────────────────────────────────────
RCLONE_REMOTE_NAME=private-s3
RCLONE_VFS_CACHE_MAX_SIZE=80G          # adjust to your local SSD size
RCLONE_ACCESS_KEY=                     # MinIO / S3 access key
RCLONE_SECRET_KEY=                     # MinIO / S3 secret key
RCLONE_ENDPOINT=                       # e.g. http://192.168.1.10:9000
RCLONE_BUCKET=                         # bucket name to mount

# ─────────────────────────────────────────────────────────────
# Gluetun VPN Settings (fill these for your provider)
# ─────────────────────────────────────────────────────────────
VPN_SERVICE_PROVIDER=                  # e.g. mullvad, protonvpn, nordvpn, custom
VPN_TYPE=wireguard                     # or openvpn
# Add more gluetun variables here if needed:
# WIREGUARD_PRIVATE_KEY=...
# SERVER_COUNTRIES=...
# etc. (see gluetun docs for your provider)
